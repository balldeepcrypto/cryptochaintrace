{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "NODE_ENV=production BASE_PATH=/ PORT=3000 pnpm --filter @workspace/wallet-tracer run build",
  "outputDirectory": "artifacts/wallet-tracer/dist/public",
  "functions": {
    "api/[...route].ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
